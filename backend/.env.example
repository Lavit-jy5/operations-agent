APP_NAME=Agent Brief Writer API
APP_ENV=development
FRONTEND_ORIGIN=http://localhost:5173

# Wind 后台工具预留。前端不再作为 Wind 查询台展示。
WIND_API_MODE=mock
WIND_USERNAME=
WIND_PASSWORD=

# 百炼大模型平台。填好 DASHSCOPE_API_KEY 后即可调用真实模型。
LLM_PROVIDER=bailian
DASHSCOPE_API_KEY=
LLM_API_KEY=
LLM_MODEL=qwen-plus
VISION_MODEL=qwen3.7-plus
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_TIMEOUT_SECONDS=60
